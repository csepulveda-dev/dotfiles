{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mastra": {
      "type": "local",
      "command": ["npx", "-y", "@mastra/mcp-docs-server"],
      "enabled": true
    }
  },
  "agent": {
    "gg": {
      "description": "Primary GlossGenius development assistant",
      "mode": "primary",
      "capabilities": ["planning", "implementation", "analysis", "coordination"]
    },
    "ggplan": {
      "description": "GlossGenius planning and architecture specialist",
      "mode": "subagent",
      "capabilities": ["architecture", "requirements", "technical_specs", "migration_planning"]
    },
    "ggbuild": {
      "description": "GlossGenius implementation and build specialist",
      "mode": "subagent",
      "capabilities": ["code_generation", "testing", "deployment", "quality_assurance"]
    },
    "ggspec": {
      "description": "Pre-implementation speckit agent. Full read access to the codebase for context, but writes are restricted to specs/ and .specify/ only. Used automatically for speckit.gg-specify/clarify/plan/tasks/analyze/checklist/constitution/init.",
      "mode": "subagent",
      "permission": {
        "edit": {
          "*": "deny",
          "specs/**": "allow",
          ".specify/**": "allow",
          ".specify-current-feature": "allow"
        },
        "write": {
          "*": "deny",
          "specs/**": "allow",
          ".specify/**": "allow",
          ".specify-current-feature": "allow"
        },
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "ls": "allow",
          "pwd": "allow",
          "echo *": "allow",
          "cat *": "allow",
          "mkdir *": "allow",
          "chmod *": "allow",
          "bash .specify/scripts/bash/*.sh*": "allow",
          "bash ~/.speckit/scripts/bash/*.sh*": "allow",
          "bash ~/.claude/speckit/scripts/bash/*.sh*": "allow"
        }
      }
    }
  },
  "command": {
    "speckit.gg-specify":     { "agent": "ggspec" },
    "speckit.gg-clarify":     { "agent": "ggspec" },
    "speckit.gg-plan":        { "agent": "ggspec" },
    "speckit.gg-tasks":       { "agent": "ggspec" },
    "speckit.gg-checklist":   { "agent": "ggspec" },
    "speckit.gg-analyze":     { "agent": "ggspec" },
    "speckit.gg-constitution":{ "agent": "ggspec" },
    "speckit.gg-init":        { "agent": "ggspec" },
    "speckit.gg-taskstoissues":{ "agent": "ggspec" },
    "speckit.gg-implement":   { "agent": "ggbuild" },
    "speckit.gg-revise":      { "agent": "ggbuild" }
  },
  "skills": {
    "core_services": {
      "path": "~/.config/opencode/skills/gg-core-services-agent",
      "commands": [
        "gg-domain-model", "gg-create-store", "gg-create-operations",
        "gg-client-integration", "gg-testing-suite", "gg-quality-check",
        "gg-analyze-architecture", "gg-db-migration", "gg-add-dependencies",
        "gg-feed-integration"
      ],
      "supports": ["core-bookings", "core-payments", "core-users", "core-inventory",
                   "core-notifications", "core-analytics", "core-integrations"]
    },
    "core_bookings_legacy": {
      "path": "~/.config/opencode/skills/core-bookings-kotlin-agent",
      "deprecated": true,
      "replacement": "core_services"
    }
  },
  "tui": {
    "scroll_acceleration": {
      "enabled": true
    }
  }
}
